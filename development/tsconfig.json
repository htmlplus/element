{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "experimentalDecorators": true,
		"jsx": "react-jsx",
    "jsxImportSource": "@htmlplus/element",
    "rootDir": "..",
    "paths": {
      "@htmlplus/element": ["../src/client/index.ts"],
      "@htmlplus/element/*": ["../src/client/*"],
      "@htmlplus/element/jsx-runtime": ["../src/jsx-runtime"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx"]
}
